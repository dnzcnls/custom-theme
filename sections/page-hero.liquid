{%- comment -%}Page header for boutique / journal / about{%- endcomment -%}
<section class="page-head" style="border-bottom:1px solid var(--border);">
  {%- if section.settings.eyebrow != blank -%}
    <div class="page-eyebrow">{{ section.settings.eyebrow }}</div>
  {%- endif -%}
  <h1 class="page-title">{{ section.settings.title }}</h1>
  {%- if section.settings.subtitle != blank -%}
    <p class="page-subtitle" style="max-width:560px; margin:24px auto 0; color:var(--muted-fg);">{{ section.settings.subtitle }}</p>
  {%- endif -%}
  {%- if section.blocks.size > 0 -%}
    <div style="display:flex; justify-content:center; gap:32px; margin-top:40px; font-size:11px; letter-spacing:0.22em; text-transform:uppercase;">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}">{{ block.settings.label }}</a>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Page hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Collection MMXXV" },
    { "type": "text", "id": "title", "label": "Title", "default": "The Boutique" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle" }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [{ "name": "Page hero" }]
}
{% endschema %}
