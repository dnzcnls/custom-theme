{%- comment -%}
  Editable product showcase. Each block is an independent product card
  the merchant edits directly in the theme editor — no Shopify product
  catalog required. Optionally link the block to a real Shopify product.
{%- endcomment -%}

<section style="padding-top: 96px; padding-bottom: 96px;">
  <div class="section-heading">
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <div class="section-eyebrow">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="section-title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>
    {%- if section.settings.view_all_link != blank and section.settings.view_all_text != blank -%}
      <a href="{{ section.settings.view_all_link }}" class="text-xs tracking-luxe hover-underline" style="display:none;" data-show-desktop>
        {{ section.settings.view_all_text }} →
      </a>
    {%- endif -%}
  </div>

  <div class="product-grid cols-{{ section.settings.columns }}">
    {%- for block in section.blocks -%}
      {%- if block.type == 'product' -%}
        {%- assign linked = all_products[block.settings.product] -%}
        {%- assign href = block.settings.link -%}
        {%- if href == blank and linked != blank and linked.url != blank -%}{%- assign href = linked.url -%}{%- endif -%}
        {%- if href == blank -%}{%- assign href = '#' -%}{%- endif -%}

        <a href="{{ href }}" class="product-card" {{ block.shopify_attributes }}>
          <div class="product-card-img">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 800 }}"
                   alt="{{ block.settings.image.alt | escape | default: block.settings.name }}"
                   loading="lazy" width="800" height="1000">
            {%- elsif block.settings.fallback_asset != blank -%}
              <img src="{{ block.settings.fallback_asset | asset_url }}"
                   alt="{{ block.settings.name | escape }}" loading="lazy">
            {%- elsif linked != blank and linked.featured_image -%}
              <img src="{{ linked.featured_image | image_url: width: 800 }}"
                   alt="{{ linked.title | escape }}" loading="lazy">
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
          {%- if block.settings.category != blank -%}
            <div class="product-card-cat">{{ block.settings.category }}</div>
          {%- endif -%}
          <div class="product-card-name">{{ block.settings.name | default: linked.title }}</div>
          {%- if block.settings.price != blank -%}
            <div class="product-card-price">{{ block.settings.price }}</div>
          {%- elsif linked != blank -%}
            <div class="product-card-price">{{ linked.price | money_without_trailing_zeros }}</div>
          {%- endif -%}
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>
<style>@media(min-width:768px){[data-show-desktop]{display:inline-block !important;}}</style>

{% schema %}
{
  "name": "Product showcase",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Sélection" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Pieces of the Season" },
    { "type": "select", "id": "columns", "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ], "default": "4" },
    { "type": "text", "id": "view_all_text", "label": "View all label", "default": "View All" },
    { "type": "url", "id": "view_all_link", "label": "View all link" }
  ],
  "max_blocks": 24,
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "fallback_asset", "label": "Fallback asset filename",
          "info": "e.g. product-coat.jpg — used if no image is uploaded." },
        { "type": "text", "id": "category", "label": "Category label", "default": "Outerwear" },
        { "type": "text", "id": "name", "label": "Name", "default": "Product Name" },
        { "type": "text", "id": "price", "label": "Price (displayed as text)", "default": "$0" },
        { "type": "url", "id": "link", "label": "Custom link" },
        { "type": "product", "id": "product", "label": "Or link to a Shopify product" }
      ]
    }
  ],
  "presets": [{
    "name": "Product showcase",
    "blocks": [
      { "type": "product", "settings": { "fallback_asset": "product-coat.jpg",     "category": "Outerwear", "name": "Maison Belted Trench",     "price": "$2,480", "link": "/pages/boutique" } },
      { "type": "product", "settings": { "fallback_asset": "product-dress.jpg",    "category": "Dresses",   "name": "Noir Bias Slip Dress",     "price": "$1,890", "link": "/pages/boutique" } },
      { "type": "product", "settings": { "fallback_asset": "product-necklace.jpg", "category": "Necklaces", "name": "Muse Solitaire Pendant",   "price": "$3,650", "link": "/pages/boutique" } },
      { "type": "product", "settings": { "fallback_asset": "product-earrings.jpg", "category": "Earrings",  "name": "Perla Drop Earrings",      "price": "$1,240", "link": "/pages/boutique" } }
    ]
  }]
}
{% endschema %}
